# Copy this file to .env and fill in your values.
# Docker Compose reads .env automatically — no extra flags needed.

# Required
WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Galaxy to monitor (ID must match the number in the GH resource link)
GALAXY_ID=68
GALAXY_NAME=SWG Infinity

# Optional overrides
FEED_URL=https://feeds.feedburner.com/GalaxyHarvesterResourceActivity
POLL_INTERVAL=300
LOG_LEVEL=INFO
